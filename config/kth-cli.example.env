# kth-cli — user preferences template
#
# Copy this file to ~/.config/kth-cli/config.env and edit the values to
# match your KTH affiliation. The kth-* CLIs source it at startup. All
# values are optional — if unset, the CLI either prompts or errors with
# a helpful message.
#
# IMPORTANT: this file is not in the repo. Don't commit your real
# preferences upstream. The example template lives at
# <repo>/config/kth-cli.example.env in the repo, with placeholder values.

# ─── Identity ───────────────────────────────────────────────────────
# Your full display name as it appears in WISUM / KTH. Used as the
# default value on the Godsmärkning (parcel label) field and as a
# fallback selector when locating form inputs that pre-populate with
# the logged-in user's name.
export KTH_USER_NAME="Your Name"

# Your KTH ID (the SSO username, 4 letters). Auto-detected from the
# Unit4 session at runtime, so this is optional — only set if a
# command needs it before the first session call.
export KTH_USER_ID="YOURID"

# Email Findity / Findity-style services match you against. Defaults to
# "${KTH_USER_ID}@kth.se" if unset. Set explicitly if your Findity
# account uses a different form (e.g. firstname.lastname@kth.se).
# export KTH_USER_EMAIL="your-kth-id@kth.se"

# ─── WISUM defaults ─────────────────────────────────────────────────
# Default Enhet (KTH organisational unit) for `kth wisum checkout`.
# Pick yours from `kth wisum enheter` after first sign-in.
export KTH_WISUM_ENHET="YOUR_UNIT"

# Default delivery address for `kth wisum checkout`.
# Pick yours from `kth wisum addresses` after first sign-in.
export KTH_WISUM_ADDRESS="YOUR_ADDRESS"

# Default Godsmärkning (parcel label) — typically your full name.
# Override per-order with `--godsmarkning "<text>"` when receiving a
# cart forwarded from a lab member.
export KTH_WISUM_GODSMARKNING="$KTH_USER_NAME"

# ─── EFH (Unit4 invoice) defaults ───────────────────────────────────
# Path to your project-accounts routing rules. See
# <repo>/config/project-accounts.example.yaml for the schema.
# If unset, the EFH commands look in this default location.
export KTH_EFH_PROJECT_ACCOUNTS="$HOME/.config/kth-cli/project-accounts.yaml"

# ─── Profile ────────────────────────────────────────────────────────
# Where agent-browser stores cookies / IndexedDB / service-workers for
# the warm SSO session. Default `~/.config/browser-profile` is shared
# across every agent-browser-backed CLI on this user account (KTH SAML,
# Frontiers Loop, etc. coexist there via domain-scoped cookies). Set
# only if you specifically want an isolated profile for one tool.
# export KTH_PROFILE_DIR="$HOME/.config/browser-profile-isolated"
