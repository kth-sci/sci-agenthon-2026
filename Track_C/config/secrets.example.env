# kth-cli — provider Admin / Billing API keys template.
#
# Copy this file to ~/.config/kth-cli/secrets.env (mode 0600) and fill
# in the keys for the providers you use. The kth-receipts CLI reads
# this file the same way the other kth-* CLIs read config.env.
#
# IMPORTANT:
#   • This file holds live credentials. Never commit it. Never share it.
#   • Each key gives org-level read access. Rotate via the provider's
#     admin-keys page if any of these leak.
#   • Leave a slot blank if you don't have an account for that provider.

# ── OPENAI Admin API keys ────────────────────────────────────────────
# Generate at: https://platform.openai.com/settings/organization/admin-keys
# Choose: Custom permissions → Invoices=read, Costs=read, Usage=read.
# Key format starts with "sk-admin-…"
#
# One key per Google account you use to sign in to OpenAI. Add as
# many <SLOT> variables as you need; the kth-receipts CLI recognises
# OEWAY and WEI by default — add more by editing bin/kth-receipts
# (`_resolve_account` switch).
export KTH_OPENAI_KEY_OEWAY=""              # for account 1 email
export KTH_OPENAI_KEY_WEI=""                # for account 2 email

# ── ANTHROPIC Admin API keys ─────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/admin-keys
# Anthropic's Admin keys are not granularly scoped — they give full
# read access to the organisation's billing + usage data.
# Key format starts with "sk-ant-admin01-…"
export KTH_ANTHROPIC_KEY_OEWAY=""           # for account 1 email
export KTH_ANTHROPIC_KEY_WEI=""             # for account 2 email

# ── KTH CANVAS access token ──────────────────────────────────────────
# Personal access token for the KTH Canvas LMS REST API (used by
# `kth canvas`). NOT the SAML cookie — mint it at:
#   https://canvas.kth.se/profile/settings
#     → Approved Integrations → "+ New Access Token" → Generate.
# The token is shown ONCE. Either paste it here, or let `kth canvas`
# store it at ~/.config/kth-cli/.canvas-token via `kth canvas token --set`.
# Token format looks like:  NNNN~<long base64-ish string>
export KTH_CANVAS_TOKEN=""

# ── USAGE ────────────────────────────────────────────────────────────
# After filling these in:
#   kth receipts accounts                       # confirm all four are set
#   kth receipts whoami anthropic-oeway         # which org does the key auth into?
#   kth receipts costs openai-oeway --days 90   # daily API spend for the window
#   kth receipts costs anthropic-wei --month 2026-04
#
# Important: the Admin APIs expose COST and USAGE data, but NOT invoice
# PDFs. Stripe-issued PDFs for ChatGPT Plus / Claude.ai Pro subscriptions
# live behind each provider's billing portal and must be downloaded by
# hand. `kth receipts scan` will help marshal them for upload to Findity.
